# ──────────────────────────────────────────────────────────────────────────────
# FlightsScanner — environment template
# Copy to `.env` and adjust. Local defaults are safe for `docker compose up`.
# NEVER commit a real `.env`. See docs/auth-and-security.md.
# ──────────────────────────────────────────────────────────────────────────────

# ── General ───────────────────────────────────────────────────────────────────
ENVIRONMENT=development            # development | production

# ── Postgres ──────────────────────────────────────────────────────────────────
POSTGRES_DB=flights
POSTGRES_USER=flights
POSTGRES_PASSWORD=flights
POSTGRES_PORT=5432

# Connection DSNs.
#   - Async (asyncpg)   → used by the FastAPI request path.
#   - Sync  (psycopg2)  → used by Celery workers and Alembic migrations.
# Host is the Compose service name `postgres`; use `localhost` when running bare-metal.
DATABASE_URL=postgresql+asyncpg://flights:flights@postgres:5432/flights
DATABASE_URL_SYNC=postgresql+psycopg2://flights:flights@postgres:5432/flights

# ── Redis (Celery broker + price cache) ───────────────────────────────────────
REDIS_URL=redis://redis:6379/0
REDIS_PORT=6379

# ── Backend API ───────────────────────────────────────────────────────────────
BACKEND_PORT=8000
SECRET_KEY=change-me-in-prod                      # backend token signing — set a long random value in prod
BACKEND_CORS_ORIGINS=http://localhost:3000        # comma-separated allow-list (never use *)

# ── Caching / quota ───────────────────────────────────────────────────────────
CACHE_TTL_SECONDS=14400            # price cache TTL: 4 hours
PROVIDER_DAILY_QUOTA=1000          # max real provider calls per provider per UTC day

# ── Flight provider ───────────────────────────────────────────────────────────
FLIGHT_PROVIDER=mock               # mock | amadeus
# Only needed when FLIGHT_PROVIDER=amadeus:
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=
AMADEUS_BASE_URL=https://test.api.amadeus.com

# ── Frontend (Next.js / NextAuth) ─────────────────────────────────────────────
FRONTEND_PORT=3000
# Browser → backend (published host port):
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
# Server (Next.js container) → backend (Compose DNS):
API_BASE_URL=http://backend-api:8000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-in-prod                 # `openssl rand -base64 32`
